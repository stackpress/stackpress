enum Role {
  ADMIN "ADMIN"
  EDITOR "EDITOR"
  USER "USER"
}

type Address @icon("address") @labels("Address" "Addresses") {
  street   String
           @label("Street Address")
           @field.input({ type "text" placeholder "123 Main St" })
           @view.string
  city     String
           @label("City")
           @field.input({ type "text" placeholder "Anytown" })
           @list.string @view.string
  state    String?
           @label("State")
           @field.input({ type "text" placeholder "CA" })
           @view.string
  zipCode  String
           @label("Postal Code")
           @is.ce(5)
           @field.input({ type "text" placeholder "12345" })
           @list.string @view.string
  country  String
           @label("Country")
           @field.country({ defaultValue "US" })
           @list.country @view.country
}

model BasicModel
  @display("{{title}}")
  @icon("basic")
  @labels("Basic Model" "Basic Models")
  @query("*")
{
  title       String 
              @label("Title") 
              @field.input @list.string @view.string
  description Text @label("Description") 
              @field.textarea @list.string @view.string
  price       Number @label("Price") 
              @field.price @list.price @view.price
  age         Integer @label("Age")
  height      Float @label("Height")
  active      Boolean @label("Is Active")
  publishAt   Date @label("Publish Date")
  showAt      Time @label("Show Time")
  createdAt   Datetime @label("Created At")
  references  Hash @label("References")
  data        Json @label("Data")
  cache       Object @label("Cache")
  role        Role @label("Role")
  address     Address @label("Address")
  sink        KitchenSink[]
}

model KitchenSink
  @display("{{title}}")
  @icon("sink")
  @labels("The Kitchen Sink" "Kitchen Sinks")
  @query("*" "basic.*")
{
  id          String    
              @label("ID") 
              @id @default("cuid()")
              @list.overflow({ length 10 hellip true })
              @description("Unique generated identifier.")
              @example("pjfdz7tg8bcf7e2lig3iuej3")
  basicId     String
              @label("Basic Model") 
              @description("1:1 Relation to BasicModel model.")
              @field.relation({ 
                id "id"
                search "/admin/profile/search?json&q={{QUERY}}"
                template "{{name}}" 
              }) 
              @list.relation({ id "id" template "{{name}}" })
              @view.relation({ id "id" template "{{name}}" })
  title       String
              @label("Title") 
              @searchable @unique
              @is.notempty @is.unique @is.neq("Untitled") @is.cge(5) @is.clt(255)
              @field.input({ type "text" placeholder "Enter title here" })
              @list.link({ to "/admin/kitchensink/{{id}}" })
              @view.string
              @description("Title of the item.")
              @example("Sample Title")
  notes       String?
              @label("Notes") 
              @is.wlt(50)
              @field.textarea({ rows 4 placeholder "Enter notes here" })
              @view.text
  description Text
              @field.text
  bio         Text?
              @field.markdown
              @view.markdown
  email       String
              @encrypted
              @is.email
              @field.email
              @view.email
  password    String
              @hashed
              @field.password
  currency    String
              @is.regex("^[A-Z]{3}$" "Must be a valid 3-letter currency code.")
              @field.currency
              @filter.currency
              @list.lowercase
              @view.uppercase
  price       Number? 
              @min(0) @step(0.01)
              @is.ge(0) @is.price
              @field.price
              @list.price
              @view.price
  age         Integer
              @sortable @min(0) @max(100) @step(1) @default(18)
              @is.ge(0) @is.le(100)
              @field.slider({ min 0 max 100 step 1 })
              @span.slider({ min 0 max 100 step 1 })
              @list.number
              @view.number
  height      Float
              @sortable @max(10) @step(0.1) @default(5.5)
              @is.le(10)
              @field.number({ min 0 max 10 step 0.1 })
  tags        String[]
              @field.tags
              @list.tags
              @view.tags
  keywords    String[]
              @field.textlist
              @view.spread({ separator ", " })
  rating      Integer
              @min(1) @max(5) @step(1)
              @is.ge(1) @is.le(5)
              @field.rating
              @list.rating
              @view.rating
  ratings     Number[]
  comments    Object[]
  history     Datetime[]
  role        Role
              @default("USER")
              @is.option("ADMIN" "EDITOR" "USER" "Should be valid role")
              @field.select(options ["ADMIN" "EDITOR" "USER"])
  secondRole  Role?
              @is.option("ADMIN" "EDITOR" "USER" "Should be valid role")
              @field.select(options ["ADMIN" "EDITOR" "USER"])
  approved    Boolean
              @default(false)
              @field.checkbox
              @list.yesno
              @view.yesno
  homeAddress Address
              @field.fieldset
              @list.fieldset
              @view.fieldset
  workAddress Address?
              @field.fieldset
              @view.fieldset
  addressBook Address[]
              @field.fieldset
              @view.fieldset
  active      Boolean
              @label("Is Active")
              @active @default(true)
              @field.switch
              @list.yesno
              @view.yesno
  publishAt   Date?
              @sortable
              @is.date @is.future
              @field.date
  showAt      Time
              @field.time
  createdAt   Datetime
              @sortable @default("now()")
  updatedAt   Datetime
              @sortable @default("now()") @updated
  references  Hash 
              @default({})
              @field.metadata
  data        Json 
              @default("{}")
  cache       Object?
  basic       BasicModel @relation({ local "basicId" foreign "title" })
}

model User {
  id          String @id @default("cuid()")
  name        String
  networks    Network[]
  memberships Network[]
}

model Network @query("*" "owner.*" "member.*") {
  ownerId  String @id
  memberId String @id
  owner   User @relation({ name "networks" local "ownerId" foreign "id" })
  member  User @relation({ name "memberships" local "memberId" foreign "id" })
}