{
  "type": "module",
  "name": "stackpress-session",
  "version": "0.9.2",
  "license": "MIT",
  "description": "Session handler library for the Stackpress framework.",
  "author": "Chris <chris@stackpress.io>",
  "homepage": "https://www.stackpress.io/",
  "bugs": "https://github.com/stackpress/stackpress/issues",
  "repository": "stackpress/stackpress",
  "plugins": [
    "./cjs/plugin.js"
  ],
  "main": "./cjs/index.js",
  "module": "./esm/index.js",
  "types": "./cjs/index.d.ts",
  "exports": {
    "./events/*": {
      "require": "./cjs/events/*.js",
      "import": "./esm/events/*.js"
    },
    "./pages/*": {
      "require": "./cjs/pages/*.js",
      "import": "./esm/pages/*.js"
    },
    "./views/*": {
      "require": "./cjs/views/*.js",
      "import": "./esm/views/*.js"
    },
    "./actions": {
      "require": "./cjs/actions.js",
      "import": "./esm/actions.js"
    },
    "./Exception": {
      "require": "./cjs/Exception.js",
      "import": "./esm/Exception.js"
    },
    "./helpers": {
      "require": "./cjs/helpers.js",
      "import": "./esm/helpers.js"
    },
    "./plugin": {
      "require": "./cjs/plugin.js",
      "import": "./esm/plugin.js"
    },
    "./Session": {
      "require": "./cjs/Session.js",
      "import": "./esm/Session.js"
    },
    "./types": {
      "require": "./cjs/types.js",
      "import": "./esm/types.js"
    },
    ".": {
      "require": "./cjs/index.js",
      "import": "./esm/index.js"
    },
    "./esm/views/*": "./esm/views/*.js",
    "./cjs/views/*": "./cjs/views/*.js",
    "./styles.css": "./styles.css"
  },
  "typesVersions": {
    "*": {
      "events/*": [
        "./cjs/events/*.d.ts"
      ],
      "pages/*": [
        "./cjs/pages/*.d.ts"
      ],
      "views/*": [
        "./cjs/views/*.d.ts"
      ],
      "actions": [
        "./cjs/actions.d.ts"
      ],
      "Exception": [
        "./cjs/Exception.d.ts"
      ],
      "helpers": [
        "./cjs/helpers.d.ts"
      ],
      "plugin": [
        "./cjs/plugin.d.ts"
      ],
      "Session": [
        "./cjs/Session.d.ts"
      ],
      "types": [
        "./cjs/types.d.ts"
      ],
      ".": [
        "./cjs/index.d.ts"
      ],
      "esm/views/*": [
        "./esm/views/*.d.ts"
      ],
      "cjs/views/*": [
        "./cjs/views/*.d.ts"
      ]
    }
  },
  "files": [
    "cjs",
    "esm",
    "LICENSE",
    "README.md",
    "styles.css"
  ],
  "scripts": {
    "build": "yarn build:tsc && yarn build:pkg",
    "build:pkg": "yarn build:pkg:cjs && yarn build:pkg:esm",
    "build:pkg:cjs": "echo '{\"type\": \"commonjs\"}' > cjs/package.json",
    "build:pkg:esm": "echo '{\"type\": \"module\"}' > esm/package.json",
    "build:tsc": "yarn build:tsc:cjs && yarn build:tsc:esm",
    "build:tsc:cjs": "tsc -p ./tsconfig.cjs.json",
    "build:tsc:esm": "tsc -p ./tsconfig.esm.json",
    "report": "nyc report -r lcov",
    "test": "yarn test:env nyc ts-mocha -r tsx tests/**/*.test.ts",
    "test:env": "NODE_OPTIONS=\"--disable-warning=ExperimentalWarning --experimental-loader @istanbuljs/esm-loader-hook\""
  },
  "dependencies": {
    "jose": "6.2.0",
    "stackpress-csrf": "0.9.2",
    "stackpress-sql": "0.9.2",
    "stackpress-view": "0.9.2"
  },
  "devDependencies": {
    "@istanbuljs/esm-loader-hook": "0.3.0",
    "@types/chai": "4.3.20",
    "@types/mocha": "10.0.10",
    "@types/node": "25.3.5",
    "chai": "4.5.0",
    "mocha": "10.8.2",
    "mocha-lcov-reporter": "1.3.0",
    "nyc": "17.1.0",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
