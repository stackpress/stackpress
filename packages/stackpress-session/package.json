{
  "type": "module",
  "name": "stackpress-session",
  "version": "0.9.1",
  "license": "MIT",
  "description": "Session handler library for the Stackpress framework.",
  "author": "Chris <chris@stackpress.io>",
  "homepage": "https://www.stackpress.io/",
  "bugs": "https://github.com/stackpress/stackpress/issues",
  "repository": "stackpress/stackpress",
  "plugins": [
    "./cjs/plugin.js"
  ],
  "main": "./cjs/index.js",
  "module": "./esm/index.js",
  "types": "./cjs/index.d.ts",
  "exports": {
    "./auth/views/*": {
      "require": "./cjs/auth/views/*.js",
      "import": "./esm/auth/views/*.js"
    },
    "./session/views/*": {
      "require": "./cjs/session/views/*.js",
      "import": "./esm/session/views/*.js"
    },
    
    "./Exception": {
      "require": "./cjs/Exception.js",
      "import": "./esm/Exception.js"
    },
    "./plugin": {
      "require": "./cjs/plugin.js",
      "import": "./esm/plugin.js"
    },
    "./types": {
      "require": "./cjs/types.js",
      "import": "./esm/types.js"
    },
    ".": {
      "require": "./cjs/index.js",
      "import": "./esm/index.js"
    },

    "./esm/auth/views/*": "./esm/auth/views/*.js",
    "./cjs/auth/views/*": "./cjs/auth/views/*.js",
    "./esm/session/views/*": "./esm/session/views/*.js",
    "./cjs/session/views/*": "./cjs/session/views/*.js",
    "./styles.css": "./styles.css"
  },
  "typesVersions": {
    "*": {
      "auth/views/*": [ "./cjs/auth/views/*.d.ts" ],
      "session/views/*": [ "./cjs/session/views/*.d.ts" ],

      "Exception": [ "./cjs/Exception.d.ts" ],
      "plugin": [ "./cjs/plugin.d.ts" ],
      "types": [ "./cjs/types.d.ts" ],
      ".": [ "./cjs/index.d.ts" ],
      
      "esm/auth/views/*": [ "./esm/auth/views/*.d.ts" ],
      "cjs/auth/views/*": [ "./cjs/auth/views/*.d.ts" ],
      "esm/session/views/*": [ "./esm/session/views/*.d.ts" ],
      "cjs/session/views/*": [ "./cjs/session/views/*.d.ts" ]
    }
  },
  "files": [
    "cjs",
    "esm",
    "LICENSE",
    "README.md",
    "styles.css"
  ],
  "scripts": {
    "build": "yarn build:tsc && yarn build:pkg",
    "build:pkg": "yarn build:pkg:cjs && yarn build:pkg:esm",
    "build:pkg:cjs": "echo '{\"type\": \"commonjs\"}' > cjs/package.json",
    "build:pkg:esm": "echo '{\"type\": \"module\"}' > esm/package.json",
    "build:tsc": "yarn build:tsc:cjs && yarn build:tsc:esm",
    "build:tsc:cjs": "tsc -p ./tsconfig.cjs.json",
    "build:tsc:esm": "tsc -p ./tsconfig.esm.json",
    "report": "nyc report -r lcov",
    "test": "yarn test:env nyc ts-mocha -r tsx tests/**/*.test.ts",
    "test:env": "NODE_OPTIONS=\"--disable-warning=ExperimentalWarning --experimental-loader @istanbuljs/esm-loader-hook\""
  },
  "dependencies": {
    "jose": "6.2.0",
    "qrcode": "1.5.4",
    "stackpress-csrf": "0.9.1",
    "stackpress-sql": "0.9.1",
    "stackpress-view": "0.9.1"
  },
  "devDependencies": {
    "@istanbuljs/esm-loader-hook": "0.3.0",
    "@types/chai": "4.3.20",
    "@types/mocha": "10.0.10",
    "@types/node": "25.3.5",
    "@types/qrcode": "1.5.3",
    "chai": "4.5.0",
    "mocha": "10.8.2",
    "mocha-lcov-reporter": "1.3.0",
    "nyc": "17.1.0",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
