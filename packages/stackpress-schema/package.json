{
  "type": "module",
  "name": "stackpress-schema",
  "version": "0.9.1",
  "license": "MIT",
  "description": "Server library for the Stackpress framework.",
  "author": "Chris <chris@stackpress.io>",
  "homepage": "https://www.stackpress.io/",
  "bugs": "https://github.com/stackpress/stackpress/issues",
  "repository": "stackpress/stackpress",
  "plugins": [
    "./cjs/plugin.js"
  ],
  "main": "./cjs/index.js",
  "module": "./esm/index.js",
  "types": "./cjs/index.d.ts",
  "exports": {
    "./ColumnInterface": {
      "require": "./cjs/interface/ColumnInterface.js",
      "import": "./esm/interface/ColumnInterface.js"
    },
    "./DefinitionInterface": {
      "require": "./cjs/interface/DefinitionInterface.js",
      "import": "./esm/interface/DefinitionInterface.js"
    },
    "./SchemaInterface": {
      "require": "./cjs/interface/SchemaInterface.js",
      "import": "./esm/interface/SchemaInterface.js"
    },

    "./Attribute": {
      "require": "./cjs/Attribute.js",
      "import": "./esm/Attribute.js"
    },
    "./AttributeAssertion": {
      "require": "./cjs/attribute/AttributeAssertion.js",
      "import": "./esm/attribute/AttributeAssertion.js"
    },
    "./AttributeComponent": {
      "require": "./cjs/attribute/AttributeComponent.js",
      "import": "./esm/attribute/AttributeComponent.js"
    },
    "./AttributeReference": {
      "require": "./cjs/attribute/AttributeReference.js",
      "import": "./esm/attribute/AttributeReference.js"
    },
    "./Attributes": {
      "require": "./cjs/attribute/Attributes.js",
      "import": "./esm/attribute/Attributes.js"
    },

    "./Column": {
      "require": "./cjs/Column.js",
      "import": "./esm/Column.js"
    },
    "./ColumnAssertion": {
      "require": "./cjs/column/ColumnAssertion.js",
      "import": "./esm/column/ColumnAssertion.js"
    },
    "./ColumnComponent": {
      "require": "./cjs/column/ColumnComponent.js",
      "import": "./esm/column/ColumnComponent.js"
    },
    "./ColumnDocument": {
      "require": "./cjs/column/ColumnDocument.js",
      "import": "./esm/column/ColumnDocument.js"
    },
    "./ColumnName": {
      "require": "./cjs/column/ColumnName.js",
      "import": "./esm/column/ColumnName.js"
    },
    "./ColumnNumber": {
      "require": "./cjs/column/ColumnNumber.js",
      "import": "./esm/column/ColumnNumber.js"
    },
    "./Columns": {
      "require": "./cjs/column/Columns.js",
      "import": "./esm/column/Columns.js"
    },
    "./ColumnStore": {
      "require": "./cjs/column/ColumnStore.js",
      "import": "./esm/column/ColumnStore.js"
    },
    "./ColumnType": {
      "require": "./cjs/column/ColumnType.js",
      "import": "./esm/column/ColumnType.js"
    },
    "./ColumnValue": {
      "require": "./cjs/column/ColumnValue.js",
      "import": "./esm/column/ColumnValue.js"
    },

    "./Fieldset": {
      "require": "./cjs/Fieldset.js",
      "import": "./esm/Fieldset.js"
    },
    "./FieldsetAssertion": {
      "require": "./cjs/fieldset/FieldsetAssertion.js",
      "import": "./esm/fieldset/FieldsetAssertion.js"
    },
    "./FieldsetComponent": {
      "require": "./cjs/fieldset/FieldsetComponent.js",
      "import": "./esm/fieldset/FieldsetComponent.js"
    },
    "./FieldsetDocument": {
      "require": "./cjs/fieldset/FieldsetDocument.js",
      "import": "./esm/fieldset/FieldsetDocument.js"
    },
    "./FieldsetName": {
      "require": "./cjs/fieldset/FieldsetName.js",
      "import": "./esm/fieldset/FieldsetName.js"
    },
    "./FieldsetType": {
      "require": "./cjs/fieldset/FieldsetType.js",
      "import": "./esm/fieldset/FieldsetType.js"
    },
    "./FieldsetValue": {
      "require": "./cjs/fieldset/FieldsetValue.js",
      "import": "./esm/fieldset/FieldsetValue.js"
    },

    "./Model": {
      "require": "./cjs/Model.js",
      "import": "./esm/Model.js"
    },
    "./ModelStore": {
      "require": "./cjs/model/ModelStore.js",
      "import": "./esm/model/ModelStore.js"
    },

    "./config/attributes": {
      "require": "./cjs/config/attributes.js",
      "import": "./esm/config/attributes.js"
    },
    "./config/definitions": {
      "require": "./cjs/config/definitions.js",
      "import": "./esm/config/definitions.js"
    },
    "./config/typemaps": {
      "require": "./cjs/config/typemaps.js",
      "import": "./esm/config/typemaps.js"
    },

    "./transform/helpers": {
      "require": "./cjs/transform/helpers.js",
      "import": "./esm/transform/helpers.js"
    },
    "./transform": {
      "require": "./cjs/transform/index.js",
      "import": "./esm/transform/index.js"
    },

    "./Exception": {
      "require": "./cjs/Exception.js",
      "import": "./esm/Exception.js"
    },
    "./Revisions": {
      "require": "./cjs/Revisions.js",
      "import": "./esm/Revisions.js"
    },
    "./Schema": {
      "require": "./cjs/Schema.js",
      "import": "./esm/Schema.js"
    },

    "./dictionary": {
      "require": "./cjs/dictionary.js",
      "import": "./esm/dictionary.js"
    },
    "./helpers": {
      "require": "./cjs/helpers.js",
      "import": "./esm/helpers.js"
    },
    "./plugin": {
      "require": "./cjs/plugin.js",
      "import": "./esm/plugin.js"
    },
    "./types": {
      "require": "./cjs/types.js",
      "import": "./esm/types.js"
    },
    ".": {
      "require": "./cjs/index.js",
      "import": "./esm/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "ColumnInterface": [ "./cjs/interface/ColumnInterface.d.ts" ],
      "DefinitionInterface": [ "./cjs/interface/DefinitionInterface.d.ts" ],
      "SchemaInterface": [ "./cjs/interface/SchemaInterface.d.ts" ],
      
      "Attribute": [ "./cjs/Attribute.d.ts" ],
      "AttributeAssertion": [ "./cjs/attribute/AttributeAssertion.d.ts" ],
      "AttributeComponent": [ "./cjs/attribute/AttributeComponent.d.ts" ],
      "AttributeReference": [ "./cjs/attribute/AttributeReference.d.ts" ],
      "Attributes": [ "./cjs/attribute/Attributes.d.ts" ],
      
      "Column": [ "./cjs/Column.d.ts" ],
      "ColumnAssertion": [ "./cjs/column/ColumnAssertion.d.ts" ],
      "ColumnComponent": [ "./cjs/column/ColumnComponent.d.ts" ],
      "ColumnDocument": [ "./cjs/column/ColumnDocument.d.ts" ],
      "ColumnName": [ "./cjs/column/ColumnName.d.ts" ],
      "ColumnNumber": [ "./cjs/column/ColumnNumber.d.ts" ],
      "Columns": [ "./cjs/column/Columns.d.ts" ],
      "ColumnStore": [ "./cjs/column/ColumnStore.d.ts" ],
      "ColumnType": [ "./cjs/column/ColumnType.d.ts" ],
      "ColumnValue": [ "./cjs/column/ColumnValue.d.ts" ],
      
      "Fieldset": [ "./cjs/Fieldset.d.ts" ],
      "FieldsetAssertion": [ "./cjs/fieldset/FieldsetAssertion.d.ts" ],
      "FieldsetComponent": [ "./cjs/fieldset/FieldsetComponent.d.ts" ],
      "FieldsetDocument": [ "./cjs/fieldset/FieldsetDocument.d.ts" ],
      "FieldsetName": [ "./cjs/fieldset/FieldsetName.d.ts" ],
      "FieldsetType": [ "./cjs/fieldset/FieldsetType.d.ts" ],
      "FieldsetValue": [ "./cjs/fieldset/FieldsetValue.d.ts" ],
      
      "Model": [ "./cjs/Model.d.ts" ],
      "ModelStore": [ "./cjs/model/ModelStore.d.ts" ],
      
      "config/attributes": [ "./cjs/config/attributes.d.ts" ],
      "config/definitions": [ "./cjs/config/definitions.d.ts" ],
      "config/typemaps": [ "./cjs/config/typemaps.d.ts" ],

      "transform/helpers": [ "./cjs/transform/helpers.d.ts" ],
      "transform": [ "./cjs/transform/index.d.ts" ],

      "Exception": [ "./cjs/Exception.d.ts" ],
      "Revisions": [ "./cjs/Revisions.d.ts" ],
      "Schema": [ "./cjs/Schema.d.ts" ],
      
      "dictionary": [ "./cjs/dictionary.d.ts" ],
      "helpers": [ "./cjs/helpers.d.ts" ],
      "plugin": [ "./cjs/plugin.d.ts" ],
      "types": [ "./cjs/types.d.ts" ],
      ".": [ "./cjs/index.d.ts" ]
    }
  },
  "files": [
    "cjs",
    "esm",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "yarn build:tsc && yarn build:pkg",
    "build:pkg": "yarn build:pkg:cjs && yarn build:pkg:esm",
    "build:pkg:cjs": "echo '{\"type\": \"commonjs\"}' > cjs/package.json",
    "build:pkg:esm": "echo '{\"type\": \"module\"}' > esm/package.json",
    "build:tsc": "yarn build:tsc:cjs && yarn build:tsc:esm",
    "build:tsc:cjs": "tsc -p ./tsconfig.cjs.json",
    "build:tsc:esm": "tsc -p ./tsconfig.esm.json",
    "report": "nyc report -r lcov",
    "test": "yarn test:env nyc ts-mocha -r tsx tests/**/*.test.ts",
    "test:env": "NODE_OPTIONS=\"--disable-warning=ExperimentalWarning --experimental-loader @istanbuljs/esm-loader-hook\""
  },
  "dependencies": {
    "@stackpress/idea-parser": "0.8.3",
    "@stackpress/idea-transformer": "0.8.3",
    "stackpress-server": "0.9.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@istanbuljs/esm-loader-hook": "0.3.0",
    "@types/chai": "4.3.20",
    "@types/mocha": "10.0.10",
    "@types/node": "25.3.5",
    "chai": "4.5.0",
    "mocha": "10.8.2",
    "mocha-lcov-reporter": "1.3.0",
    "nyc": "17.1.0",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
