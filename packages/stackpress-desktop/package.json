{
  "type": "module",
  "name": "stackpress-desktop",
  "version": "0.10.7",
  "license": "MIT",
  "description": "Desktop application target for Stackpress apps.",
  "stackpressDesktopRationale": {
    "dependencies": {
      "@stackpress/ingest": "Composes the existing Stackpress plugin and terminal lifecycle instead of creating a parallel runtime.",
      "electron": "Provides the native desktop shell for the selected local HTTP runtime."
    },
    "devDependencies": {
      "electron-builder": "First current-platform packaging adapter for unsigned app artifacts or actionable packaging failures.",
      "typescript": "Matches the monorepo TypeScript package build convention.",
      "tsx": "Runs TypeScript test files under the monorepo test loader setup.",
      "ts-mocha": "Provides the package TypeScript test command used by the desktop workspace.",
      "mocha": "Test runner for desktop package behavior and contracts.",
      "chai": "Assertions for desktop package tests.",
      "nyc": "Coverage wrapper matching neighboring package test scripts."
    }
  },
  "author": "Chris <chris@stackpress.io>",
  "homepage": "https://www.stackpress.io/",
  "bugs": "https://github.com/stackpress/stackpress/issues",
  "repository": "stackpress/stackpress",
  "plugins": [
    "./cjs/plugin.js"
  ],
  "main": "./cjs/index.js",
  "module": "./esm/index.js",
  "types": "./cjs/index.d.ts",
  "exports": {
    "./plugin": {
      "require": "./cjs/plugin.js",
      "import": "./esm/plugin.js"
    },
    "./events": {
      "require": "./cjs/events/index.js",
      "import": "./esm/events/index.js"
    },
    "./events/*": {
      "require": "./cjs/events/*.js",
      "import": "./esm/events/*.js"
    },
    "./scripts": {
      "require": "./cjs/scripts/index.js",
      "import": "./esm/scripts/index.js"
    },
    "./scripts/*": {
      "require": "./cjs/scripts/*.js",
      "import": "./esm/scripts/*.js"
    },
    "./types": {
      "require": "./cjs/types.js",
      "import": "./esm/types.js"
    },
    ".": {
      "require": "./cjs/index.js",
      "import": "./esm/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "plugin": [
        "./cjs/plugin.d.ts"
      ],
      "events": [
        "./cjs/events/index.d.ts"
      ],
      "events/*": [
        "./cjs/events/*.d.ts"
      ],
      "scripts": [
        "./cjs/scripts/index.d.ts"
      ],
      "scripts/*": [
        "./cjs/scripts/*.d.ts"
      ],
      "types": [
        "./cjs/types.d.ts"
      ],
      ".": [
        "./cjs/index.d.ts"
      ]
    }
  },
  "files": [
    "cjs",
    "esm",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "yarn build:tsc && yarn build:pkg",
    "build:pkg": "yarn build:pkg:cjs && yarn build:pkg:esm",
    "build:pkg:cjs": "echo '{\"type\": \"commonjs\"}' > cjs/package.json",
    "build:pkg:esm": "echo '{\"type\": \"module\"}' > esm/package.json",
    "build:tsc": "yarn build:tsc:cjs && yarn build:tsc:esm",
    "build:tsc:cjs": "tsc -p ./tsconfig.cjs.json",
    "build:tsc:esm": "tsc -p ./tsconfig.esm.json",
    "report": "nyc report -r lcov",
    "test": "yarn test:env nyc ts-mocha -r tsx tests/**/*.test.ts",
    "test:env": "NODE_OPTIONS=\"--disable-warning=ExperimentalWarning --experimental-loader @istanbuljs/esm-loader-hook\""
  },
  "dependencies": {
    "@stackpress/ingest": "0.10.7",
    "electron": "^42.4.0"
  },
  "devDependencies": {
    "@istanbuljs/esm-loader-hook": "0.3.0",
    "@types/chai": "4.3.20",
    "@types/mocha": "10.0.10",
    "@types/node": "25.3.5",
    "chai": "4.5.0",
    "electron-builder": "^26.15.3",
    "mocha": "10.8.2",
    "mocha-lcov-reporter": "1.3.0",
    "nyc": "17.1.0",
    "ts-mocha": "^11.1.0",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
