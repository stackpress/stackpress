{
  "type": "module",
  "name": "stackpress-view",
  "version": "0.9.1",
  "license": "MIT",
  "description": "View library for the Stackpress framework.",
  "author": "Chris <chris@stackpress.io>",
  "homepage": "https://www.stackpress.io/",
  "bugs": "https://github.com/stackpress/stackpress/issues",
  "repository": "stackpress/stackpress",
  "plugins": [
    "./cjs/plugin.js"
  ],
  "main": "./cjs/index.js",
  "module": "./esm/index.js",
  "types": "./cjs/index.d.ts",
  "exports": {
    "./client/types": {
      "require": "./cjs/client/types.js",
      "import": "./esm/client/types.js"
    },
    "./client": {
      "require": "./cjs/client/index.js",
      "import": "./esm/client/index.js"
    },
    "./config/*": {
      "require": "./cjs/config/*.js",
      "import": "./esm/config/*.js"
    },
    "./layout/*": {
      "require": "./cjs/layout/*.js",
      "import": "./esm/layout/*.js"
    },
    "./server/*": {
      "require": "./cjs/server/*.js",
      "import": "./esm/server/*.js"
    },
    "./theme/*": {
      "require": "./cjs/theme/*.js",
      "import": "./esm/theme/*.js"
    },
    "./transform": {
      "require": "./cjs/transform/index.js",
      "import": "./esm/transform/index.js"
    },

    "./Exception": {
      "require": "./cjs/Exception.js",
      "import": "./esm/Exception.js"
    },
    "./helpers": {
      "require": "./cjs/helpers.js",
      "import": "./esm/helpers.js"
    },
    "./plugin": {
      "require": "./cjs/plugin.js",
      "import": "./esm/plugin.js"
    },
    "./types": {
      "require": "./cjs/types.js",
      "import": "./esm/types.js"
    },
    ".": {
      "require": "./cjs/index.js",
      "import": "./esm/index.js"
    },

    "./cjs/layout/*": "./cjs/layout/*.js",
    "./esm/layout/*": "./esm/layout/*.js",
    "./cjs/server/*": "./cjs/server/*.js",
    "./esm/server/*": "./esm/server/*.js",
    "./cjs/theme/*": "./cjs/theme/*.js",
    "./esm/theme/*": "./esm/theme/*.js",

    "./styles.css": "./styles.css"
  },
  "typesVersions": {
    "*": {
      "client/types": [ "./cjs/client/types.d.ts" ],
      "client": [ "./cjs/client/index.d.ts" ],
      "config/*": [ "./cjs/config/*.d.ts" ],
      "layout/*": [ "./cjs/layout/*.d.ts" ],
      "server/*": [ "./cjs/server/*.d.ts" ],
      "theme/*": [ "./cjs/theme/*.d.ts" ],
      "transform": [ "./cjs/transform/index.d.ts" ],

      "Exception": [ "./cjs/Exception.d.ts" ],
      "helpers": [ "./cjs/helpers.d.ts" ],
      "plugin": [ "./cjs/plugin.d.ts" ],
      "types": [ "./cjs/types.d.ts" ],
      ".": [ "./cjs/index.d.ts" ],

      "cjs/layout/*": [ "./cjs/layout/*.d.ts" ],
      "esm/layout/*": [ "./esm/layout/*.d.ts" ],
      "cjs/server/*": [ "./cjs/server/*.d.ts" ],
      "esm/server/*": [ "./esm/server/*.d.ts" ],
      "cjs/theme/*": [ "./cjs/theme/*.d.ts" ],
      "esm/theme/*": [ "./esm/theme/*.d.ts" ]
    }
  },
  "files": [
    "cjs",
    "esm",
    "bin.ts",
    "LICENSE",
    "README.md",
    "styles.css"
  ],
  "scripts": {
    "build": "yarn build:tsc && yarn build:pkg",
    "build:pkg": "yarn build:pkg:cjs && yarn build:pkg:esm",
    "build:pkg:cjs": "echo '{\"type\": \"commonjs\"}' > cjs/package.json",
    "build:pkg:esm": "echo '{\"type\": \"module\"}' > esm/package.json",
    "build:tsc": "yarn build:tsc:cjs && yarn build:tsc:esm",
    "build:tsc:cjs": "tsc -p ./tsconfig.cjs.json",
    "build:tsc:esm": "tsc -p ./tsconfig.esm.json",
    "report": "nyc report -r lcov",
    "test": "yarn test:env nyc ts-mocha -r tsx tests/**/*.test.ts",
    "test:env": "NODE_OPTIONS=\"--disable-warning=ExperimentalWarning --experimental-loader @istanbuljs/esm-loader-hook\""
  },
  "dependencies": {
    "frui": "0.2.7",
    "r22n": "1.0.10",
    "reactus": "0.8.3",
    "stackpress-language": "0.9.1",
    "stackpress-schema": "0.9.1"
  },
  "devDependencies": {
    "@istanbuljs/esm-loader-hook": "0.3.0",
    "@types/chai": "4.3.20",
    "@types/mocha": "10.0.10",
    "@types/node": "25.3.5",
    "chai": "4.5.0",
    "mocha": "10.8.2",
    "mocha-lcov-reporter": "1.3.0",
    "nyc": "17.1.0",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
