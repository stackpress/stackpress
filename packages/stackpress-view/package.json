{
  "type": "module",
  "name": "stackpress-view",
  "version": "0.9.1",
  "license": "MIT",
  "description": "View library for the Stackpress framework.",
  "author": "Chris <chris@stackpress.io>",
  "homepage": "https://www.stackpress.io/",
  "bugs": "https://github.com/stackpress/stackpress/issues",
  "repository": "stackpress/stackpress",
  "plugins": [
    "./cjs/plugin.js"
  ],
  "main": "./cjs/index.js",
  "module": "./esm/index.js",
  "types": "./cjs/index.d.ts",
  "exports": {
    "./client": {
      "require": "./cjs/client.js",
      "import": "./esm/client.js"
    },
    "./helpers": {
      "require": "./cjs/helpers.js",
      "import": "./esm/helpers.js"
    },
    "./import": {
      "require": "./cjs/import.js",
      "import": "./esm/import.js"
    },
    "./plugin": {
      "require": "./cjs/plugin.js",
      "import": "./esm/plugin.js"
    },
    "./transform": {
      "require": "./cjs/transform/index.js",
      "import": "./esm/transform/index.js"
    },
    "./types": {
      "require": "./cjs/types.js",
      "import": "./esm/types.js"
    },
    ".": {
      "require": "./cjs/index.js",
      "import": "./esm/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "client": [ "./cjs/client.d.ts" ],
      "helpers": [ "./cjs/helpers.d.ts" ],
      "import": [ "./cjs/import.d.ts" ],
      "mysql": [ "./cjs/mysql.d.ts" ],
      "pglite": [ "./cjs/pglite.d.ts" ],
      "pgsql": [ "./cjs/pgsql.d.ts" ],
      "plugin": [ "./cjs/plugin.d.ts" ],
      "sqlite": [ "./cjs/sqlite.d.ts" ],
      "transform": [ "./cjs/transform/index.d.ts" ],
      "types": [ "./cjs/types.d.ts" ],
      ".": [ "./cjs/index.d.ts" ]
    }
  },
  "files": [
    "cjs",
    "esm",
    "bin.ts",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "yarn build:tsc && yarn build:pkg",
    "build:pkg": "yarn build:pkg:cjs && yarn build:pkg:esm",
    "build:pkg:cjs": "echo '{\"type\": \"commonjs\"}' > cjs/package.json",
    "build:pkg:esm": "echo '{\"type\": \"module\"}' > esm/package.json",
    "build:tsc": "yarn build:tsc:cjs && yarn build:tsc:esm",
    "build:tsc:cjs": "tsc -p ./tsconfig.cjs.json",
    "build:tsc:esm": "tsc -p ./tsconfig.esm.json",
    "report": "nyc report -r lcov",
    "test": "yarn test:env nyc ts-mocha -r tsx tests/**/*.test.ts",
    "test:env": "NODE_OPTIONS=\"--disable-warning=ExperimentalWarning --experimental-loader @istanbuljs/esm-loader-hook\""
  },
  "dependencies": {
    "stackpress-schema": "0.9.1"
  },
  "devDependencies": {
    "@istanbuljs/esm-loader-hook": "0.3.0",
    "@types/chai": "4.3.20",
    "@types/mocha": "10.0.10",
    "@types/node": "25.3.5",
    "chai": "4.5.0",
    "mocha": "10.8.2",
    "mocha-lcov-reporter": "1.3.0",
    "nyc": "17.1.0",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
