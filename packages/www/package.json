{
  "type": "module",
  "name": "stackpress-www",
  "version": "0.10.5",
  "private": true,
  "plugins": [
    "./plugins/app/plugin",
    "./plugins/home/plugin",
    "./plugins/concepts/plugin",
    "./plugins/guides/plugin",
    "./plugins/api/plugin",
    "stackpress"
  ],
  "scripts": {
    "build": "stackpress build --b config/build -v",
    "dev": "stackpress serve --b config/develop -v",
    "emit": "stackpress emit",
    "preview": "stackpress serve --b config/preview -v"
  },
  "dependencies": {
    "mermaid": "10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stackpress": "0.10.5"
  },
  "devDependencies": {
    "@types/node": "25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "fast-glob": "3.3.3",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "unocss": "66.6.6",
    "vite": "7.3.1"
  }
}
